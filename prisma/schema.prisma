generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  image     String?
  workouts  Workout[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Workout {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String? // Ej: "Día de Pierna"
  notes     String? // Notas in-workout
  sets      Set[]
  startTime DateTime  @default(now())
  endTime   DateTime? // Si es nulo, el entrenamiento sigue en curso
}

model Set {
  id        String   @id @default(cuid())
  workoutId String
  workout   Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise  String // Ej: "Press Banca"
  weight    Float // En kg
  reps      Int
  completed Boolean  @default(false) // Checkbox interactivo in-workout
  createdAt DateTime @default(now())
}
