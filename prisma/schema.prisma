generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== NEXTAUTH MODELS ====================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  emailVerified DateTime?
  image         String?
  
  // Perfil del Gym
  age           Int?
  goal          String?   // Ej: Ganar masa, Perder peso
  experience    String?   // Ej: Principiante, Intermedio, Avanzado
  
  accounts      Account[]
  sessions      Session[]
  workouts      Workout[]
  routines      Routine[]
  exercises     Exercise[]
  bodyWeightLogs BodyWeightLog[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==================== GYM MODELS ====================

// Ejercicios personalizados por el usuario
model Exercise {
  id          String   @id @default(cuid())
  name        String   
  muscleGroup String?  // Ej: Pecho, Espalda, Piernas
  trackingType String  @default("WEIGHT_REPS") // WEIGHT_REPS, REPS_ONLY, TIME
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  sets            Set[]
  routineExercises RoutineExercise[]

  @@unique([userId, name])
}

// Plantillas de Rutina creadas por el usuario
model Routine {
  id          String   @id @default(cuid())
  name        String   // Ej: "Push Day Hypertrophy"
  description String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  exercises   RoutineExercise[]
  workouts    Workout[] // Historial de veces que se ha completado esta rutina
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Los ejercicios específicos dentro de una plantilla de rutina
model RoutineExercise {
  id          String   @id @default(cuid())
  routineId   String
  routine     Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  
  exerciseId  String
  exercise    Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  
  order       Int      @default(0) // Orden dentro de la rutina
  targetSets  Int      @default(3)
  targetReps  Int      @default(10)
}

// Un entrenamiento específico que ocurre un día concreto
model Workout {
  id        String   @id @default(cuid())
  name      String   // Puede heredar de la rutina
  startTime DateTime @default(now())
  endTime   DateTime?
  notes     String?  @db.Text
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  routineId String?
  routine   Routine? @relation(fields: [routineId], references: [id], onDelete: SetNull)
  
  sets      Set[]
}

// Las series reales registradas durante un entrenamiento
model Set {
  id        String   @id @default(cuid())
  weight    Float    @default(0)
  reps      Int      @default(0)
  rpe       Int?     // Nivel de esfuerzo (1-10)
  completed Boolean  @default(false)
  
  workoutId String
  workout   Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  
  createdAt  DateTime @default(now())
}

// Registro de peso corporal del usuario
model BodyWeightLog {
  id        String   @id @default(cuid())
  weight    Float
  date      DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

